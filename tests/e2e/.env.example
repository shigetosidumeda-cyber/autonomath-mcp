# tests/e2e/.env.example — copy to `.env.e2e` (gitignored) and edit.
#
# JPINTEL_E2E_BASE_URL is the origin the browser navigates to. It must
# serve BOTH the static site (site/) and the API (/v1/*) under a single
# origin — same-origin is what dashboard.js + success.html assume by default.
#
# Three recommended targets:
#
#   1) Local dev (default)
#        terminal A: uvicorn jpintel_mcp.api.main:app --port 8080 --reload
#        terminal B: (cd site && python -m http.server 8090)
#        terminal C: a reverse proxy (caddy / nginx) merging 8090 + 8080 at 8088
#        JPINTEL_E2E_BASE_URL=http://localhost:8088
#
#      For the simplest one-terminal flow without a proxy:
#        uvicorn jpintel_mcp.api.main:app --port 8080  +
#        (cd site && python -m http.server 8080 &)  will collide.
#      Use the staging URL or launch a proxy. The `scripts/e2e_serve.sh` helper
#      (to be added if needed) wires this up locally.
#
#   2) Fly staging (CI default)
#        JPINTEL_E2E_BASE_URL=https://jpintel-mcp-staging.fly.dev
#
#   3) Production smoke (manual only; --run-production flag required)
#        JPINTEL_E2E_BASE_URL=https://jpintel-mcp.fly.dev

JPINTEL_E2E_BASE_URL=http://localhost:8080

# Optional: pre-seeded API key for dashboard flow tests. If unset, the test
# fixture creates one via direct DB insert (local dev) and skips (staging).
JPINTEL_E2E_API_KEY=

# Optional: local SQLite path for the fixture that seeds usage_events.
# Only honoured when the target is localhost. Staging + prod never allow
# direct DB writes from tests.
JPINTEL_E2E_DB_PATH=./data/jpintel.db

# Headless override. `1` or `true` = headless (CI default). `0` = headed
# (local debugging). Defaults to headless.
JPINTEL_E2E_HEADLESS=1

# Optional: skip flag for the anon rate limit test when the middleware isn't
# yet deployed to the staging target. The test self-detects by default.
JPINTEL_E2E_SKIP_ANON_LIMIT=0
