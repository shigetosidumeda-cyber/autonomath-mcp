      "pattern": "faq_or_notice_reorder",
      "symptoms": "FAQ、Q&A、お知らせ一覧の順序だけ変わる",
      "mitigation": "section item hashing with sorted stable keys; flag only add/remove/changed item bodies"
    },
    {
      "pattern": "pdf_pagination_drift",
      "symptoms": "ページ番号、ヘッダ/フッタ、改ページ位置の違い",
      "mitigation": "drop page headers/footers and page-number-only lines before text hash"
