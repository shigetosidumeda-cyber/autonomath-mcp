  "field_normalization": [
    "Normalize Unicode with NFKC, collapse whitespace, strip zero-width and control characters.",
    "Canonicalize URLs by lowercasing scheme/host, removing tracking query params, preserving PDF/doc path and meaningful fragments separately.",
    "Convert amount_max_man_yen and amount_min_man_yen to integer yen before comparison.",
    "Normalize subsidy_rate to decimal max rate; do not diff display forms such as 1/2 vs 0.5.",
    "Parse application_window_json into start_date/end_date/status/fiscal_year/round/cycle and compare typed fields, not raw JSON order.",
    "Sort and de-duplicate target_types/funding_purpose arrays before hashing.",
    "For laws, compare law_number, law_title, enforced_date, last_amended_date, revision_status, and source_checksum separately from fetched_at.",
    "For HTML/PDF text, strip boilerplate zones before low-level difflib: footer/contact/nav/cookie/accessibility/sidebar/breadcrumb/script/style."
  ],
  "snapshot_cycle_recommendation": {
    "open_or_near_deadline_tier_s": "daily while status=open or application_window end_date is present/current; compare typed fields first",
    "stable_open_ended_loan_tax_pages": "weekly content hash plus typed field check",
    "e_gov_laws": "weekly catalog checksum, immediate candidate if last_amended_date or revision_status differs",
    "broken_sources": "retry with backoff and keep 3-strike quarantine evidence separate from business diff",
    "missing_checksum_rows": "prioritize checksum backfill before declaring field diff"
  },
  "false_positive_taxonomy": [
    {
      "pattern": "boilerplate_footer_contact",
      "symptoms": "電話番号、所在地、組織改編、SNS/footer link changes",
      "mitigation": "zone-strip footer/contact/nav before text hash; keep contact as low-signal auxiliary field"
    },
    {
      "pattern": "dynamic_timestamp_counter",
      "symptoms": "現在時刻、最終表示日時、access counter、cache bust query",
      "mitigation": "regex remove timestamps/counters; compare business dates only after label whitelist"
    },
    {
      "pattern": "faq_or_notice_reorder",
      "symptoms": "FAQ、Q&A、お知らせ一覧の順序だけ変わる",
      "mitigation": "section item hashing with sorted stable keys; flag only add/remove/changed item bodies"
    },
    {
      "pattern": "pdf_pagination_drift",
      "symptoms": "ページ番号、ヘッダ/フッタ、改ページ位置の違い",
      "mitigation": "drop page headers/footers and page-number-only lines before text hash"
    },
    {
      "pattern": "minor_particle_wording",
      "symptoms": "て・に・を・は、句読点、全半角、令和/西暦併記の揺れ",
      "mitigation": "NFKC + token-level similarity; suppress if high-signal fields unchanged"
    },
    {
      "pattern": "list_page_churn",
      "symptoms": "公募一覧ページで他制度の追加が混ざる",
      "mitigation": "program-specific heading window extraction; fallback to source URL detail page or attachment"
    },
    {
      "pattern": "historical_ingest_metadata",
      "symptoms": "enriched_json 内の worker_id/model/fetched_at/quality_self_score changes",
      "mitigation": "exclude ingestion metadata from normalized_business_sha256"
    }
  ],
  "shard_false_positive_focus": [
    "boilerplate footers and contact sections",
