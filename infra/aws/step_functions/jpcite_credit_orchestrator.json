    },
    "Aggregate_Run_Manifest": {
      "Type": "Pass",
      "Comment": "Compose run-level pointer payload from all 7 parallel branch outputs. Each Batch job is expected to PutObject run_manifest.json under its output_prefix; the downstream Task writes a run-level pointer to the reports bucket. Final SNS announces aggregation readiness — operator runs scripts/aws_credit_ops/aggregate_run_ledger.py for the credit_run_ledger_2026_05.json roll-up.",
      "Parameters": {
        "RunId.$": "$$.Execution.Name",
        "StartedAt.$": "$$.Execution.StartTime",
        "Jobs": {
          "J01.$": "States.JsonToString($.parallel_result[0])",
          "J02.$": "States.JsonToString($.parallel_result[1])",
          "J03.$": "States.JsonToString($.parallel_result[2])",
          "J04.$": "States.JsonToString($.parallel_result[3])",
          "J05.$": "States.JsonToString($.parallel_result[4])",
          "J06.$": "States.JsonToString($.parallel_result[5])",
          "J07.$": "States.JsonToString($.parallel_result[6])"
        }
      },
      "ResultPath": "$.aggregate_payload",
      "Next": "Write_Aggregate_Manifest"
    },
