                "JobDefinition": "arn:aws:batch:ap-northeast-1:993693061769:job-definition/jpcite-crawl-heavy",
                "ContainerOverrides": {
                  "Environment": [
                    { "Name": "JPCITE_JOB_ID", "Value": "J01_deep_source_profile_sweep" },
                    { "Name": "JPCITE_MANIFEST_S3", "Value": "s3://jpcite-credit-993693061769-202605-reports/manifests/J01_deep_source_profile_sweep.json" },
                    { "Name": "JPCITE_CREDIT_RUN", "Value": "2026-05" },
                    { "Name": "AWS_REGION", "Value": "ap-northeast-1" }
                  ]
                }
              },
              "Retry": [
                {
                  "ErrorEquals": ["Batch.AWSBatchException", "States.TaskFailed"],
                  "IntervalSeconds": 30,
                  "MaxAttempts": 1,
                  "BackoffRate": 2.0
                }
              ],
              "Catch": [
                {
                  "ErrorEquals": ["States.ALL"],
                  "Next": "J01_Failed_Notify",
                  "ResultPath": "$.error"
                }
              ],
              "End": true
            },
            "J01_Failed_Notify": {
              "Type": "Task",
              "Resource": "arn:aws:states:::aws-sdk:cloudwatch:putMetricData",
              "Parameters": {
                "Namespace": "jpcite/credit",
                "MetricData": [
                  {
                    "MetricName": "CatchInvocations",
                    "Value": 1,
                    "Unit": "Count",
                    "Dimensions": [
                      {"Name": "CatchSource", "Value": "J01_deep_source_profile_sweep"},
                      {"Name": "RunId", "Value.$": "$$.Execution.Name"}
                    ]
                  }
                ]
              },
              "End": true
            }
          }
        },
