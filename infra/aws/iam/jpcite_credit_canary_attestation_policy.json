{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BatchReadOnly",
      "Effect": "Allow",
      "Action": [
        "batch:ListJobs",
        "batch:DescribeJobs"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CostExplorerReadOnly",
      "Effect": "Allow",
      "Action": [
        "ce:GetCostAndUsage"
      ],
      "Resource": "*"
    },
    {
      "Sid": "S3ListRawAndDerived",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::jpcite-credit-993693061769-202605-raw",
        "arn:aws:s3:::jpcite-credit-993693061769-202605-derived",
        "arn:aws:s3:::jpcite-credit-993693061769-202605-reports"
      ]
    },
    {
      "Sid": "S3PutAttestation",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectTagging"
      ],
      "Resource": "arn:aws:s3:::jpcite-credit-993693061769-202605-reports/attestations/*"
    },
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
