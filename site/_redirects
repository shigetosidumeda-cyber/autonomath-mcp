/account     /dashboard.html  302

# ─────────────────────────────────────────────────────────────────────────
# Jinja2 source-template leak guard.
#
# `site/_templates/*.html` are Jinja2 source files (program.html, qa.html,
# cross.html, prefecture.html, news_post.html, industry_program.html,
# prefecture_index.html). They are read by scripts/generate_*_pages.py and
# rendered into final HTML at /programs/*, /qa/*/*.html, /prefectures/*,
# /industries/*, /news/*. The raw .html files contain unrendered `{{ var }}`
# placeholders — if they leaked to the public domain, search engines would
# index broken markup. This rule marks the path gone (404) so Cloudflare
# Pages refuses to serve them even if they end up in the deploy artifact.
# Cloudflare Pages `_redirects` supports 200/301/302/303/307/308/404.
# We use 404 (resource permanently absent) instead of 410 because CF Pages
# rejects unknown status codes. /404 itself is the existing /404.html page.
/_templates/*  /404  404

# ─────────────────────────────────────────────────────────────────────────
# 2026-04-29 SEO AI-feel reduction — retired SSG pages.
#
# The site was producing 12,629 generated SEO pages (programs S/A/B/C × cross
# 47×10 × qa × industries). 84% of those landed in tier B/C territory whose
# coverage was thin and read as AI-generated boilerplate. We collapsed the
# static surface to ~2,000 high-signal pages:
#   - programs/    : 10,953 → 1,413 (tier S+A only, B/C searchable via API)
#   - cross/       : 470    → 47    (47 prefecture hubs, top 10 inline)
#   - qa/          : 99     → 30    (curated high-volume queries)
#   - industries/  : 1,049  → 22    (JSIC majors A..S + E-sme + L-sme + index)
#   - prefectures/ : 48     → 48    (already correct, depth upgrade only)
#
# The redirect rules below catch inbound traffic to the retired URLs and
# bounce it to the new surface. Per-program detail is always reachable via
# the API at /v1/programs/{unified_id} regardless of static-page status.
# ─────────────────────────────────────────────────────────────────────────

# Programs: tier B/C SSG pages were retired. Inbound /programs/{slug}.html
# requests that no longer match a file on disk fall through to /programs/
# (search-surface index) so users can re-search by keyword. CF Pages serves
# the file directly when the slug still exists (tier S/A), so this rule
# only fires for the retired tier B/C slugs.
/programs/*  /programs/  302

# Cross prefecture × program retired pair pages: legacy
# /cross/{pref}/{program}.html → bounce to the prefecture hub
# /cross/{pref}/. Bare /cross/{pref} resolves natively via CF .html
# stripping + the new /cross/{pref}/index.html.
/cross/:pref/:slug.html  /cross/:pref/  302
/cross/:pref/:slug       /cross/:pref/  302
/cross                   /cross/        301

# QA: 69 retired pages bounce to the FAQ / QA root.
/qa/*  /qa/  302

# Industries: retired per-program-per-JSIC pages
# /industries/{jsic}/{slug}/index.html → /industries/{jsic}/.
/industries/:jsic/:slug/index.html  /industries/:jsic/  302
/industries/:jsic/:slug/            /industries/:jsic/  302
/industries/:jsic/:slug.html        /industries/:jsic/  302
/industries/:jsic/:slug             /industries/:jsic/  302
