# ------------------------------------------------------------------
# 2026-05-12 — CDN cache strategy hot-path optimization.
# ------------------------------------------------------------------
# /v1/programs/* responses are proxied through functions/api_proxy.ts.
# The upstream API emits its own cache-control on 200 results
# (s-maxage=60), but Cloudflare Pages does not honor that without an
# explicit edge directive when the response is routed through a Pages
# Function. The headers here ensure /api/programs/* still hits the
# CF edge cache for 60s, which is the practical max for an FTS search
# surface (programs corpus is refreshed nightly; 60s cache eats >95%
# of duplicate query bursts without serving truly-stale results).
/api/programs/*
  Cache-Control: public, max-age=60, s-maxage=60
  CDN-Cache-Control: public, max-age=60
  Vary: Accept, Authorization, X-API-Key

