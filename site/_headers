# Status page — live health probe, must always re-evaluate.
# /status/index.html embeds vanilla JS that polls /v1/am/health/deep +
# PyPI every 30s. If browsers cache the HTML, users see stale "all green"
# overlays after an outage clears (or worse, stale green during one).
# max-age=0 forces revalidation on every reload; s-maxage=60 lets the edge
# absorb crawler bursts. The JS itself controls liveness — a 60s edge cache
# on the shell only hides newly-published copy edits, not the live status.
/status/*
  Cache-Control: public, max-age=0, s-maxage=60, must-revalidate
  X-Robots-Tag: index, follow

# Trial-key reveal page: no-store, noindex.
# /trial.html receives the issued key in the URL fragment (#api_key=...)
# from the magic-link verify redirect. Browsers do not send fragments to
# the server, so the key never reaches the edge cache; but the SHELL of
# the page (the JS that reads the fragment and renders it once) must
# always be fresh. A stale shell could either (a) miss a security copy
# update or (b) — worse — re-render a fragment from a previous tab if
# the user navigates back. max-age=0 + must-revalidate forces both the
# browser and the edge to revalidate on every load. X-Robots-Tag is
# belt+suspenders to the in-page <meta name="robots" content="noindex">.
/trial.html
  Cache-Control: private, no-store, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow

# Homepage — short cache, longer edge cache for crawlers.
/index.html
  Cache-Control: public, max-age=300, s-maxage=600

# /playground.html — interactive REST API try-it surface. Ships a single
# inline <script> block (~6 KB local OpenAPI mirror + fetch controller).
# The shell rarely changes (param schema is the only churn), but visitors
# return mid-evaluation and we want copy edits to reach them in minutes,
# not hours. 5 min browser / 10 min edge mirrors /index.html policy
# (similar interactive-shell pattern). Robots indexable — playground is
# part of the funnel.
/playground.html
  Cache-Control: public, max-age=300, s-maxage=600

# Data freshness and transparency pages.
/data-freshness.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

/transparency.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

# Top-level static HTML pages (about, pricing, compare, sources, tos, privacy,
# tokushoho, success, dashboard, glossary, partners, prompts, products,
# alerts, line, etc). Without an explicit rule, Cloudflare Pages does not
# edge-cache HTML, so the 2% cache hit rate measured 2026-04-29 was almost
# entirely bot crawls hitting the same URL pattern. 1h browser / 24h edge
# is conservative enough that any honest content update reaches users
# within a day, while still flattening the bandwidth curve at scale.
/*.html
  Cache-Control: public, max-age=3600, s-maxage=86400

# Per-program SEO pages — cacheable for a day, SWR a week.
/programs/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Audience landing pages and prefecture index pages.
/audiences/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/prefectures/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Geo and program cross-reference pages.
/cross/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Per-competitor comparison pages.
/compare/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Public Q&A pages.
/qa/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# English variants of every page sit under /en/. Same caching as parent.
/en/*
