# Cloudflare Pages _headers — jpcite.com
# Reference: https://developers.cloudflare.com/pages/configuration/headers/
# Generated 2026-04-25 to support /structured/*.jsonld MIME + cache headers.

# Site-wide security headers. CSP is intentionally permissive on style-src
# (mkdocs-material + per-program SEO pages use inline <style>) and on
# script-src 'unsafe-inline' because several pages ship vetted inline
# <script> blocks: success.html post-Stripe key reveal, pricing.html /
# en/pricing.html Subscribe-button + ToS-consent gate, go.html device-link
# flow, line.html waitlist, widget.html copy-snippet, index.html / 404.html
# small page-level scripts. Remote scripts remain blocked ('self' only) so
# this does not open us to third-party CDN compromise; the residual XSS
# surface is governed by server-side input sanitization (no user input is
# reflected into HTML on these pages). Future hardening: extract all inline
# blocks to self-hosted .js files and drop 'unsafe-inline'.
# `connect-src` allows the API origin (api.jpcite.com) so dashboard JS
# can fetch /v1/me/* with credentials, and pypi.org so /status/index.html can
# poll the PyPI JSON endpoint for the latest published autonomath-mcp version
# alongside the /v1/am/health/deep aggregate. JSON-LD
# <script type=application/ld+json> is parsed as data, not executed, so it is
# unaffected by script-src.
# `object-src 'none'` blocks legacy <object>/<embed>/<applet> injection.
# `frame-src 'none'` makes explicit that we never embed third-party iframes
# (Stripe checkout is a top-level redirect, not an embedded iframe). This
# does not affect form-action which already permits checkout/billing.stripe.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.jpcite.com https://pypi.org; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://checkout.stripe.com https://billing.stripe.com
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# JSON-LD structured-data feed for AI training crawlers.
# Content-Type per https://www.w3.org/TR/json-ld11/ §IANA registration.
/structured/*.jsonld
  Content-Type: application/ld+json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=86400
  X-Content-Type-Options: nosniff
  Access-Control-Allow-Origin: *

# Sitemaps must be served as XML to be parsed by Googlebot / Bingbot.
/sitemap*.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/docs/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

# RSS 2.0 announcements feed (release notes, dataset ingests, migrations).
# Served as application/rss+xml per RSS 2.0 spec; UTF-8 charset declared
# explicitly so Cloudflare's content-type sniffer does not downgrade to
# text/xml on browsers that do not advertise RSS in Accept.
/rss.xml
  Content-Type: application/rss+xml; charset=utf-8
  Cache-Control: public, max-age=3600

/en/rss.xml
  Content-Type: application/rss+xml; charset=utf-8
  Cache-Control: public, max-age=3600

# robots.txt
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

# RFC 9116 security.txt — responsible disclosure contact.
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# llms.txt / llms-full.txt — AI-friendly site map for LLM crawlers.
# Served as text/markdown per llmstxt.org convention (the file body is
# markdown-formatted with H1, blockquote TL;DR, and section link lists).
/llms.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600

/llms.en.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600

/en/llms.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600

/llms-full.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600

/llms-full.en.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600

# Status page — live health probe, must always re-evaluate.
# /status/index.html embeds vanilla JS that polls /v1/am/health/deep +
# PyPI every 30s. If browsers cache the HTML, users see stale "all green"
# overlays after an outage clears (or worse, stale green during one).
# max-age=0 forces revalidation on every reload; s-maxage=60 lets the edge
# absorb crawler bursts. The JS itself controls liveness — a 60s edge cache
# on the shell only hides newly-published copy edits, not the live status.
/status/*
  Cache-Control: public, max-age=0, s-maxage=60, must-revalidate
  X-Robots-Tag: index, follow

# Trial-key reveal page — never cache.
# /trial.html receives the raw API key in the URL fragment (#api_key=...)
# from the magic-link verify redirect. Browsers do not send fragments to
# the server, so the key never reaches the edge cache; but the SHELL of
# the page (the JS that reads the fragment and renders it once) must
# always be fresh. A stale shell could either (a) miss a security copy
# update or (b) — worse — re-render a fragment from a previous tab if
# the user navigates back. max-age=0 + must-revalidate forces both the
# browser and the edge to revalidate on every load. X-Robots-Tag is
# belt+suspenders to the in-page <meta name="robots" content="noindex">.
/trial.html
  Cache-Control: private, no-store, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow

# Homepage — short cache, longer edge cache for crawlers.
/index.html
  Cache-Control: public, max-age=300, s-maxage=600

# /playground.html — interactive REST API try-it surface. Ships a single
# inline <script> block (~6 KB local OpenAPI mirror + fetch controller).
# The shell rarely changes (param schema is the only churn), but visitors
# return mid-evaluation and we want copy edits to reach them in minutes,
# not hours. 5 min browser / 10 min edge mirrors /index.html policy
# (similar interactive-shell pattern). Robots indexable — playground is
# part of the funnel.
/playground.html
  Cache-Control: public, max-age=300, s-maxage=600

# Trust-signal pages (Wave 31): roadmap, data-freshness, transparency.
# Public roadmap, live data freshness dashboard, and source citation
# methodology page. data-freshness.html auto-polls /v1/am/data-freshness
# every 5 min from the browser, so a slightly fresher edge response is
# preferable; transparency.html and roadmap.html are static-content. 1h
# browser / 6h edge SWR matches /news/* — crawler bursts get the cached
# copy while origin re-checks in the background, content edits propagate
# within a day. Listed above /*.html so the more specific path wins on
# Cloudflare's matcher.
/roadmap.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

/data-freshness.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

/transparency.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

# Top-level static HTML pages (about, pricing, compare, sources, tos, privacy,
# tokushoho, success, dashboard, glossary, partners, prompts, products,
# alerts, line, etc). Without an explicit rule, Cloudflare Pages does not
# edge-cache HTML, so the 2% cache hit rate measured 2026-04-29 was almost
# entirely bot crawls hitting the same URL pattern. 1h browser / 24h edge
# is conservative enough that any honest content update reaches users
# within a day, while still flattening the bandwidth curve at scale.
/*.html
  Cache-Control: public, max-age=3600, s-maxage=86400

# Per-program SEO pages — cacheable for a day, SWR a week.
/programs/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Audience-targeted landing pages + prefecture index pages — same SEO
# fan-out as /programs/*, mostly read by crawlers, cache aggressively.
/audiences/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/prefectures/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Geo×program crosspages (~2,350 = 47 都道府県 × top-50 programs).
# Same caching as /programs/* — these are static SEO derivative pages
# generated by scripts/generate_geo_program_pages.py.
/cross/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Per-competitor comparison pages (/compare/{slug}/index.html).
# Hand-curated SEO + conversion pages (10 alternatives × 13-15 axes each).
# 1d browser / 7d edge SWR — content updates monthly (or on competitor TOS
# changes). Generated by scripts/generate_compare_pages.py from
# docs/compare_matrix.csv.
/compare/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Citation-targeted Q&A pages (GEO / FAQPage JSON-LD).
# Generated by scripts/generate_geo_citation_pages.py from a curated catalog
# of 76 high-volume JP-compliance questions, each backed by ≥1 primary-source
# citation (METI / NTA / 中小企業庁 / e-Gov / 公庫 / MOF). LLM crawlers
# (Perplexity / ChatGPT / Claude / Gemini) are the primary audience. Updates
# happen on quarterly source-verification cycles, so cache aggressively:
# 1 day browser / 7 days edge SWR (mirrors /programs/* policy).
/qa/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# English variants of every page sit under /en/. Same caching as parent.
/en/*
  Cache-Control: public, max-age=3600, s-maxage=86400

# Fingerprinted static assets — immutable, 1y cache.
# Note: site/styles.css and site/dashboard.js are *not* fingerprinted —
# they live at fixed paths because 10,953 generated program pages
# reference them by name. The 1y immutable cache here mainly serves
# fingerprinted mkdocs assets (site/docs/**/*.<hash>.min.css|js).
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted Noto Sans JP woff2 subsets (mkdocs theme).
# Path-fingerprinted by sha10 of the upstream gstatic URL → safe to
# cache 1y immutable. Access-Control-Allow-Origin enables cross-subdomain
# use (e.g. api.jpcite.com docs preview).
/static/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# OG / Twitter PNGs + decorative WebP previews. PNG sources stay because
# the Twitter card scraper does not reliably resolve WebP. 1-day cache
# (was 30d — caused branding-update propagation pain on 2026-04-30 logo
# refresh). Brand assets need to rotate fast when corrected.
/assets/*.png
  Cache-Control: public, max-age=86400

/assets/*.webp
  Cache-Control: public, max-age=86400

/assets/*.svg
  Cache-Control: public, max-age=86400

# Industry × program crosspages — same SEO fan-out as /programs/*, mostly
# read by crawlers, cache aggressively.
/industries/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Auto-generated news posts (制度変更検出) — fresher than /programs/* on
# purpose. /news/* is rebuilt weekly from the制度改正検出ログ so the latest
# real change is the asset that drives the SEO + GEO citation flywheel.
# 1h browser cache + 6h edge stale-while-revalidate keeps crawlers seeing
# fresh material on every recheck without thrashing the origin.
/news/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

# Integrations tutorials (Claude Desktop / Cursor / Cline / OpenAI Custom GPT)
# — hand-written 5-min step-by-step guides + SDK sample index. Mostly read by
# evaluator humans + AI crawlers. Cache 1h browser / 24h edge: copy edits to
# config snippets / version bumps reach users within a day, edge soaks up the
# burst when a new tutorial drops on Hacker News / X / Zenn.
/integrations/*
  Cache-Control: public, max-age=3600, s-maxage=86400
