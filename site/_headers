# propagates to readers within 24h without smashing the origin under
# crawler bursts.
# ------------------------------------------------------------------
/cases/*
  X-Robots-Tag: index, follow
  Cache-Control: public, max-age=86400
  CDN-Cache-Control: public, max-age=604800

/laws/*
  X-Robots-Tag: index, follow
  Cache-Control: public, max-age=86400
  CDN-Cache-Control: public, max-age=604800

