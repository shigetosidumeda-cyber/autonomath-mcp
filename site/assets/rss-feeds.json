      "tottori", "shimane", "okayama", "hiroshima", "yamaguchi",
      "tokushima", "kagawa", "ehime", "kochi",
      "fukuoka", "saga", "nagasaki", "kumamoto", "oita", "miyazaki", "kagoshima",
