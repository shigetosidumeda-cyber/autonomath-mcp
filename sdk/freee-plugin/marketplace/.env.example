# freee OAuth2 credentials (issued by freee app marketplace registration)
FREEE_CLIENT_ID=your_freee_client_id_here
FREEE_CLIENT_SECRET=your_freee_client_secret_here

# Public HTTPS URL of THIS plugin host (e.g. https://freee-plugin.zeimu-kaikei.ai)
PLUGIN_BASE_URL=https://freee-plugin.zeimu-kaikei.ai

# 税務会計AI upstream API (production)
ZEIMU_KAIKEI_API_BASE=https://api.zeimu-kaikei.ai
# server-side service key issued to THIS plugin (Bookyou-owned key, ¥3/req
# metered against the marketplace app subscription, NOT against the freee
# end-user). Get it at https://zeimu-kaikei.ai/dashboard.
ZEIMU_KAIKEI_API_KEY=zk_live_replace_me

# Express session secret (random 32+ chars). Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_openssl_rand_hex_32

# Optional: bind address / port (Fly.io sets PORT)
PORT=8080
NODE_ENV=production
