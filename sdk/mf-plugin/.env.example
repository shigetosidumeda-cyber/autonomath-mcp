# --- MF Cloud OAuth (https://app.biz.moneyforward.com/app-portal/) -----------
# CLIENT_SECRET_BASIC を推奨 (Authorization ヘッダ送信)
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_AUTHORIZE_URL=https://app.biz.moneyforward.com/oauth/authorize
MF_TOKEN_URL=https://app.biz.moneyforward.com/oauth/token
MF_REVOKE_URL=https://app.biz.moneyforward.com/oauth/revoke
# 会計 (mfc/ac/data.read) のみ要求。請求書 / 給与 等を将来追加するなら space 区切り
MF_SCOPE=mfc/ac/data.read

# --- zeimu-kaikei.ai upstream ------------------------------------------------
ZEIMU_KAIKEI_BASE_URL=https://api.zeimu-kaikei.ai
ZEIMU_KAIKEI_API_KEY=zk_live_REPLACE_ME

# --- このプラグイン自身 ------------------------------------------------------
PLUGIN_BASE_URL=https://mf-plugin.zeimu-kaikei.ai
SESSION_SECRET=REPLACE_WITH_openssl_rand_hex_32
NODE_ENV=development
PORT=8080
