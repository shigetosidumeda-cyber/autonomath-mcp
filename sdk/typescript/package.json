{
  "name": "@autonomath/sdk",
  "version": "0.3.2",
  "description": "Official TypeScript / JavaScript SDK for the jpcite REST + MCP API. Japanese institutional programs: 11,684 searchable programs + 2,286 採択事例 + 108 融資 + 1,185 行政処分 + 50 tax rulesets + laws.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "jpcite",
    "japan",
    "subsidy",
    "subsidies",
    "loans",
    "tax",
    "tax-incentives",
    "compliance",
    "mcp",
    "model-context-protocol",
    "sdk",
    "typescript",
    "rest-api",
    "japanese-government",
    "補助金",
    "融資",
    "税制"
  ],
  "homepage": "https://jpcite.com",
  "bugs": {
    "url": "https://jpcite.com/docs/",
    "email": "info@bookyou.net"
  },
  "author": {
    "name": "jpcite",
    "email": "info@bookyou.net",
    "url": "https://jpcite.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
