{
  "$id": "https://jpcite.com/schemas/jpcir/outcome_contract.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "billable": {
      "title": "Billable",
      "type": "boolean"
    },
    "cheapest_sufficient_route_required": {
      "const": true,
      "default": true,
      "title": "Cheapest Sufficient Route Required",
      "type": "boolean"
    },
    "display_name": {
      "minLength": 1,
      "title": "Display Name",
      "type": "string"
    },
    "no_hit_semantics": {
      "const": "no_hit_not_absence",
      "default": "no_hit_not_absence",
      "title": "No Hit Semantics",
      "type": "string"
    },
    "outcome_contract_id": {
      "minLength": 1,
      "title": "Outcome Contract Id",
      "type": "string"
    },
    "packet_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Packet Ids",
      "type": "array"
    },
    "public_claims_require_receipts": {
      "const": true,
      "default": true,
      "title": "Public Claims Require Receipts",
      "type": "boolean"
    }
  },
  "required": [
    "outcome_contract_id",
    "display_name",
    "packet_ids",
    "billable"
  ],
  "title": "OutcomeContract",
  "type": "object"
}
