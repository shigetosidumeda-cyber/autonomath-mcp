# Local dev defaults. On Fly, JPINTEL_DB_PATH=/data/jpintel.db is set via fly.toml.
JPINTEL_DB_PATH=./data/jpintel.db
JPINTEL_AUTONOMATH_PATH=/Users/shigetoumeda/Autonomath
# AutonoMath canonical DB (7.3 GB, 402,768 entities + 5.26M facts + 23,615
# relations). Separate file from jpintel.db above. Dev defaults to repo root
# ./autonomath.db; Fly prod mounts /data/autonomath.db via the shared volume.
AUTONOMATH_DB_PATH=./autonomath.db
# Feature flag for the 16 am_* MCP tools (search_tax_incentives, etc.).
# Set False to disable the autonomath_tools subpackage and fall back to the
# 31-tool baseline (rollback path if autonomath.db becomes unavailable).
AUTONOMATH_ENABLED=True
JPINTEL_LOG_LEVEL=INFO
JPINTEL_LOG_FORMAT=json
# Comma-separated. On staging/prod override via `flyctl secrets set JPINTEL_CORS_ORIGINS=...`
JPINTEL_CORS_ORIGINS=http://localhost:3000

# Stripe — use sk_test_* for staging. Webhook secret is PER-endpoint, so the
# staging webhook has its own whsec_* that differs from prod.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Pure metered price (¥3/req 外税, lookup_key=per_request_v3). One Price
# per environment. Legacy metered (usage_records) pinned to 2024-11-20.acacia.
STRIPE_PRICE_PER_REQUEST=price_xxx
STRIPE_API_VERSION=2024-11-20.acacia
STRIPE_BILLING_PORTAL_CONFIG_ID=bpc_xxx

# Hash salt for API keys. Regenerate per environment with:
#     openssl rand -hex 32
API_KEY_SALT=change-this-salt-in-prod
# Hard daily cap for authenticated keys with tier="free" (dunning demote —
# a paid customer whose card is failing). Paid tier is metered (no cap).
RATE_LIMIT_FREE_PER_DAY=100

# Per-IP MONTHLY quota for anonymous (no X-API-Key) callers. This IS the
# public Free tier — 50 reqs per JST calendar month per IP. Resets on the
# 1st of each month at JST 00:00. Set ANON_RATE_LIMIT_ENABLED=False to
# disable (e.g. during a DDoS storm where we replace the limiter with a
# Cloudflare WAF rule). See docs/incident_runbook.md §(e).
ANON_RATE_LIMIT_PER_MONTH=50
ANON_RATE_LIMIT_ENABLED=True

# Sentry — only populated on staging/prod. Leave blank in dev to no-op.
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=

# Environment label. "test" short-circuits the Postmark email layer so pytest
# never makes an HTTP call. Set to "prod" on Fly via `flyctl secrets set`.
JPINTEL_ENV=dev

# Postmark (transactional email). Leave the token blank in dev to no-op the
# send_* methods — they will log a structured "postmark.skip" line instead.
# Get a server token from https://account.postmarkapp.com/servers (start on
# the free 100 emails/month tier; scale to $15/mo 10k when launch volume
# warrants). See `docs/email_setup.md` for full DNS + signature setup.
POSTMARK_API_TOKEN=
# Webhook secret used to verify delivery/bounce/spam callbacks from Postmark
# hitting POST /v1/email/webhook. Generate with: openssl rand -hex 32
POSTMARK_WEBHOOK_SECRET=
# From: address for transactional mail (welcome, receipt). Must match a
# verified Sender Signature in Postmark. Recommend: no-reply@[DOMAIN]
POSTMARK_FROM_TRANSACTIONAL=
# Reply-To header — where human replies land. Recommend: hello@[DOMAIN]
POSTMARK_FROM_REPLY=
